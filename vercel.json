{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/search", "destination": "/api/search" },
    { "source": "/api/featured", "destination": "/api/featured" },
    { "source": "/api/subscribe", "destination": "/api/subscribe" },
    { "source": "/api/track", "destination": "/api/track" },
    { "source": "/api/stats", "destination": "/api/stats" },
    { "source": "/api/cron/match-subscribers", "destination": "/api/cron/match-subscribers" }
  ],
  "crons": [
    { "path": "/api/cron/match-subscribers", "schedule": "0 8 * * *" },
    { "path": "/api/morning-briefing", "schedule": "30 6 * * *" }
  ],
  "headers": [
    {
      "source": "/api/track",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/stats",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=1800" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "s-maxage=86400, stale-while-revalidate=43200" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
